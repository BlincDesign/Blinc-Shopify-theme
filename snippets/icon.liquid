{%- comment -%}
  Renders an inline SVG icon.
  Usage: {% render 'icon', name: 'account' %}
  Accepts: 'account', 'chevron', 'cart', 'play'
{%- endcomment -%}
{%- case name -%}
  {%- when 'account' -%}
    <svg class="icon icon--account" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <circle cx="12" cy="8" r="3.25"></circle>
      <path d="M4.5 19.25c1.4-3.6 4.4-5.5 7.5-5.5s6.1 1.9 7.5 5.5"></path>
    </svg>
  {%- when 'chevron' -%}
    <svg class="icon icon--chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  {%- when 'cart' -%}
    <svg class="icon icon--cart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <path d="M4 6h2l1.5 10.5a1.5 1.5 0 0 0 1.5 1.5h8a1.5 1.5 0 0 0 1.5-1.25L20 9H7"></path>
      <circle cx="10" cy="20.5" r="1.25"></circle>
      <circle cx="17" cy="20.5" r="1.25"></circle>
    </svg>
  {%- when 'play' -%}
    <svg class="icon icon--play" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
      <path d="M8 5.5v13l11-6.5z"></path>
    </svg>
{%- endcase -%}
