    "theme_documentation_url": "https://blinc.design",
    "theme_support_url": "https://blinc.design"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "header",
            "content": "Section"
          },
          {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "Background gradient"
          },
          {
            "type": "color",
            "id": "text",
            "label": "Text",
            "default": "#121212"
          },
          {
            "type": "header",
            "content": "Primary Button"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "Text",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "button",
            "label": "Background",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button_border",
            "label": "Border",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button_label_hover",
            "label": "Text (hover)",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "button_hover",
            "label": "Background (hover)",
            "default": "#2B2B2B"
          },
          {
            "type": "color",
            "id": "button_border_hover",
            "label": "Border (hover)",
            "default": "#2B2B2B"
          },
          {
            "type": "header",
            "content": "Other"
          },
          {
            "type": "color",
            "id": "accent",
            "label": "Accent",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "border",
            "label": "Lines & Borders",
            "default": "#E6E6E6"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "primary_button": "button",
          "on_primary_button": "button_label",
          "secondary_button": "background",
          "on_secondary_button": "text",
          "primary_button_border": "button_border",
          "secondary_button_border": "border",
          "links": "accent",
          "icons": "text"
        }
      }
    ]
  },
  {
